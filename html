<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="style1.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="logo">BARBER<span>PREMIUM</span></div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#servicos">Cortes</a></li>
                <li><a href="#agendar">Agendar</a></li>
                <li><a href="#contato">Contato</a></li>
            </ul>
        </nav>
    </header>

    <main class="main-container">
        <aside class="ad-sidebar left-ad">
            <p>Anúncio</p>
            <div class="ad-placeholder">Espaço Publicitário</div>
        </aside>

        <section class="content">
            <div id="home" class="hero">
                <h1>Transforme seu Visual</h1>
                <p>O melhor corte da cidade com profissionais especializados.</p>
                <a href="#agendar" class="btn-main">Agendar Agora</a>
            </div>

            <section class="info-section">
                <h2>Nosso Trabalho</h2>
                <p>Combinamos técnicas clássicas de barbearia com as últimas tendências do mercado. Ambiente climatizado e café cortesia.</p>
            </section>

            <section class="promo-banner">
                <div class="promo-card">
                    <h3>PROMO DE TERÇA</h3>
                    <p>Cabelo + Barba com 20% de desconto!</p>
                </div>
            </section>

            <section id="servicos" class="services">
                <h2>Cortes e Preços</h2>
                <div class="price-grid">
                    <div class="item"><span>Degradê Moderno</span> <span>R$ 45,00</span></div>
                    <div class="item"><span>Barba Terapia</span> <span>R$ 35,00</span></div>
                    <div class="item"><span>Corte Social</span> <span>R$ 30,00</span></div>
                    <div class="item"><span>Combo VIP</span> <span>R$ 70,00</span></div>
                </div>
            </section>

            <section id="agendar" class="booking">
                <h2>Agende seu Horário</h2>
                <form id="appointment-form">
                    <input type="text" placeholder="Seu Nome" required>
                    <input type="date" required>
                    <select>
                        <option>Selecione o Serviço</option>
                        <option>Corte</option>
                        <option>Barba</option>
                        <option>Completo</option>
                    </select>
                    <button type="submit">Confirmar Agendamento</button>
                </form>
            </section>
        </section>

        <aside class="ad-sidebar right-ad">
            <p>Anúncio</p>
            <div class="ad-placeholder">Espaço Publicitário</div>
        </aside>
    </main>

    <footer id="contato">
        <div class="footer-content">
            <div class="about">
                <h3>Sobre a Barber Premium</h3>
                <p>Fundada em 2010, nossa missão é elevar a autoestima masculina através de um atendimento personalizado e de alta qualidade.</p>
            </div>
            <div class="contact-info">
                <h3>Contato</h3>
                <p>📍 Rua dos Barbeiros, 123</p>
                <p>📞 (11) 99999-9999</p>
                <p>📧 contato@barberpremium.com</p>
            </div>
        </div>
        <p class="copy">&copy; 2023 Barber Premium - Todos os direitos reservados.</p>
    </footer>

    <script src="script1.js"></script>
    
</body>
</html>
